<!-- AI客服悬浮按钮（可拖动） -->
<view
  class="ai-float-btn"
  hover-class="ai-float-hover"
  style="left:{{x}}px; top:{{y}}px;"
  bindtouchstart="onTouchStart"
  catchtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
  catchtap="goChat"
>
  <view class="ai-icon">
    <text class="ai-line">AI</text>
    <text class="ai-line">客服</text>
  </view>
</view>

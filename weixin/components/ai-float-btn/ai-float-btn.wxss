/* AI客服悬浮按钮 - 可拖动，右下角 */
.ai-float-btn {
  position: fixed;
  width: 92rpx;
  height: 92rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #7778f3 0%, #5b5ce2 56%, #4748c9 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.35);
  box-shadow:
    0 12rpx 30rpx rgba(81, 82, 217, 0.32),
    inset 0 2rpx 3rpx rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: transform 0.15s ease;
}

/* 按压时的高级微缩反馈 */
.ai-float-hover {
  transform: scale(0.92);
  box-shadow:
    0 6rpx 16rpx rgba(81, 82, 217, 0.3),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.30);
}

.ai-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  line-height: 1.12;
}

.ai-line {
  font-size: 23rpx;
  line-height: 1.12;
  color: #ffffff;
  font-weight: 600;
  letter-spacing: 1rpx;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.18);
}

/* 第一行 AI 用更亮的点缀色，增强层次 */
.ai-line:first-child {
  background: linear-gradient(180deg, #ffffff 0%, #e8eeff 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
}

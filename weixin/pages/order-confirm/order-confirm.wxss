.container {
  padding: 24rpx;
  padding-bottom: calc(150rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.address-section {
  display: flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid rgba(20, 22, 40, 0.05);
  border-radius: 24rpx;
  padding: 30rpx 26rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 42, 72, 0.05);
}

.address-main {
  flex: 1;
  min-width: 0;
}

.addr-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 10rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #25252b;
  margin-right: 20rpx;
}

.phone {
  font-size: 28rpx;
  color: #73737c;
}

.default-tag {
  margin-left: 12rpx;
  font-size: 22rpx;
  color: #5152d9;
  background: #ededff;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.addr-text {
  display: block;
  font-size: 26rpx;
  color: #65656e;
  line-height: 1.6;
}

.no-address-text {
  display: block;
  font-size: 30rpx;
  color: #25252b;
}

.no-address-tip {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 8rpx;
}

.arrow {
  color: #b5b5bd;
  font-size: 32rpx;
  margin-left: 16rpx;
}

.form-section {
  background: #fff;
  border: 1rpx solid rgba(20, 22, 40, 0.05);
  border-radius: 24rpx;
  padding: 0 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 42, 72, 0.05);
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 104rpx;
}

.label {
  width: 100rpx;
  flex-shrink: 0;
  color: #65656e;
  font-size: 28rpx;
}

.form-item input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
}

.placeholder {
  color: #b3b3bb;
}

.order-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 -10rpx 30rpx rgba(39, 42, 72, 0.08);
}

.btn-submit {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6f70ee, #5152d9);
  color: #fff;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(81, 82, 217, 0.22);
}

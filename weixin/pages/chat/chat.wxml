<!-- AI智能客服对话页面 (流式输出 + Markdown 渲染) -->
<view class="chat-page">
  <scroll-view class="chat-list" scroll-y scroll-top="{{scrollTop}}" scroll-with-animation enhanced show-scrollbar="{{false}}">
    <view class="chat-item {{item.role}}" wx:for="{{messages}}" wx:key="id">
      <!-- 用户消息：纯文本即可 -->
      <view class="chat-bubble" wx:if="{{item.role === 'user'}}">
        <text>{{item.content}}</text>
      </view>
      <!-- AI 回复：rich-text 渲染 Markdown -->
      <view class="chat-bubble ai-bubble" wx:else>
        <rich-text nodes="{{item.htmlContent || item.content}}" />
        <view class="source-list" wx:if="{{item.sources && item.sources.length}}">
          <text class="source-title">参考来源</text>
          <text class="source-item" wx:for="{{item.sources}}" wx:for-item="source" wx:key="ref">
            [{{source.ref}}] {{source.file_name}}{{source.section_title ? ' · ' + source.section_title : ''}}
          </text>
        </view>
      </view>
      <text class="chat-time">{{item.time}}</text>
    </view>

    <!-- 流式加载中的占位 -->
    <view wx:if="{{loading && (!messages[messages.length-1] || messages[messages.length-1].role === 'user')}}" class="chat-item assistant">
      <view class="chat-bubble ai-bubble streaming-placeholder">
        <text class="streaming-dots">思考中</text>
      </view>
    </view>
  </scroll-view>

  <view class="chat-input-bar">
    <input class="chat-input" placeholder="问问装备、订单或搭配建议…" value="{{inputText}}" bindinput="onInput" confirm-type="send" bindconfirm="sendMessage" />
    <button class="btn-send" bindtap="sendMessage" disabled="{{loading}}">发送</button>
  </view>
</view>

/* ===== 页面布局 ===== */
.chat-page { display: flex; flex-direction: column; height: 100vh; background: linear-gradient(180deg, #f0f1ff 0%, #f6f7fb 24%); }
.chat-list { flex: 1; overflow-y: auto; box-sizing: border-box; padding: 24rpx 0 28rpx; }

/* ===== 消息项 ===== */
.chat-item { margin-bottom: 26rpx; padding: 0 24rpx; box-sizing: border-box; }
.chat-item.user { display: flex; flex-direction: column; align-items: flex-end; }
.chat-item.assistant { display: flex; flex-direction: column; align-items: flex-start; }

/* ===== 气泡通用 ===== */
.chat-bubble { max-width: 80%; padding: 20rpx 24rpx; border-radius: 24rpx; font-size: 28rpx; line-height: 1.7; word-break: break-all; box-sizing: border-box; }
.chat-item.user .chat-bubble { background: linear-gradient(135deg, #6f70ee, #5152d9); color: #fff; border-bottom-right-radius: 8rpx; box-shadow: 0 10rpx 24rpx rgba(81, 82, 217, .18); }

/* ===== AI 气泡（rich-text 容器）===== */
.chat-item.assistant .chat-bubble { background: #fff; color: #2c2c32; border: 1rpx solid rgba(20, 22, 40, 0.05); border-bottom-left-radius: 8rpx; box-shadow: 0 8rpx 26rpx rgba(39,42,72,0.06); }
.ai-bubble { position: relative; overflow: hidden; }
.source-list { margin-top: 18rpx; padding-top: 14rpx; border-top: 1rpx solid #ececf1; }
.source-title { display: block; color: #77788a; font-size: 22rpx; margin-bottom: 6rpx; }
.source-item { display: block; color: #5b5ce2; font-size: 21rpx; line-height: 1.55; }

/* ===== 时间戳 ===== */
.chat-time { display: block; font-size: 20rpx; color: #a0a0a8; margin-top: 8rpx; text-align: center; }

/* ===== 输入栏 ===== */
.chat-input-bar { display: flex; align-items: center; padding: 14rpx 20rpx; background: rgba(255,255,255,.97); border-top: 1rpx solid #ececf1; padding-bottom: calc(14rpx + env(safe-area-inset-bottom)); box-shadow: 0 -8rpx 26rpx rgba(39,42,72,.05); }
.chat-input { flex: 1; height: 76rpx; box-sizing: border-box; background: #f1f2f6; border-radius: 22rpx; padding: 0 22rpx; font-size: 27rpx; }
.btn-send { min-width: 112rpx; background: linear-gradient(135deg, #6f70ee, #5152d9); color: #fff; font-size: 27rpx; font-weight: 600; padding: 0 24rpx; height: 76rpx; line-height: 76rpx; margin-left: 14rpx; border-radius: 22rpx; border: none; }
.btn-send[disabled] { opacity: 0.6; }

/* ===== 流式加载动画 ===== */
.streaming-placeholder .streaming-dots {
  display: inline-block;
  color: #999;
}
.streaming-placeholder .streaming-dots::after {
  content: '...';
  animation: dots 1.5s steps(3, end) infinite;
}
@keyframes dots {
  0%   { content: '.';  }
  33%  { content: '..'; }
  66%  { content: '...'; }
}

/* ===== Markdown 渲染样式（rich-text 内嵌节点）====== */

/* 段落 */
.ai-bubble p { margin: 8rpx 0; line-height: 1.7; }

/* 加粗 - 核心需求！**text** → <strong> */
.ai-bubble strong,
.ai-bubble b { color: #1a1a1a; font-weight: bold; }

/* 斜体 */
.ai-bubble em,
.ai-bubble i { font-style: italic; color: #555; }

/* 行内代码 */
.ai-bubble code {
  background: #f0f0f0;
  color: #e74c3c;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  font-family: Consolas, Monaco, monospace;
}

/* 代码块 */
.ai-bubble pre {
  background: #2d2d2d;
  color: #f8f8f2;
  padding: 20rpx;
  border-radius: 10rpx;
  margin: 12rpx 0;
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-all;
}
.ai-bubble pre code {
  background: transparent;
  color: inherit;
  padding: 0;
  font-size: 24rpx;
}

/* 无序列表 */
.ai-bubble ul.md-list, .ai-bubble ol {
  margin: 8rpx 0;
  padding-left: 36rpx;
}
.ai-bubble li {
  margin: 6rpx 0;
  line-height: 1.7;
  list-style-position: outside;
}
/* 自定义列表圆点 */
.ai-bubble ul.md-list { list-style-type: disc; }
.ai-bubble ul.md-list > li::marker { color: #5b5ce2; font-size: 24rpx; }

/* 引用块 */
.ai-bubble blockquote {
  border-left: 6rpx solid #5b5ce2;
  padding: 12rpx 20rpx;
  margin: 12rpx 0;
  background: #f4f4ff;
  color: #666;
  border-radius: 0 8rpx 8rpx 0;
}

/* 标题 */
.ai-bubble h1 { font-size: 38rpx; font-weight: bold; margin: 16rpx 0 10rpx; color: #1a1a1a; }
.ai-bubble h2 { font-size: 34rpx; font-weight: bold; margin: 14rpx 0 8rpx; color: #222; }
.ai-bubble h3 { font-size: 30rpx; font-weight: bold; margin: 12rpx 0 6rpx; color: #333; }

/* 换行 */
.ai-bubble br { display: block; content: ''; margin: 4rpx 0; }

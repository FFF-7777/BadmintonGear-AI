.profile-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.section-card {
  background: #fff;
  border: 1rpx solid rgba(20, 22, 40, 0.05);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 42, 72, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #25252b;
  margin-bottom: 24rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
}

.avatar-img,
.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.avatar-placeholder {
  background: linear-gradient(135deg, #6f70ee, #5152d9);
  color: #fff;
  text-align: center;
  line-height: 120rpx;
  font-size: 44rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 24rpx rgba(81, 82, 217, .2);
}

.avatar-action {
  margin-left: 24rpx;
}

.avatar-tip {
  display: block;
  font-size: 28rpx;
  color: #5152d9;
  font-weight: 600;
}

.avatar-format {
  display: block;
  font-size: 22rpx;
  color: #8e8e93;
  margin-top: 10rpx;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eff0f4;
}

.label {
  width: 150rpx;
  flex-shrink: 0;
  color: #34343b;
  font-size: 28rpx;
}

.readonly {
  flex: 1;
  font-size: 28rpx;
  color: #8e8e93;
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  color: #17171c;
}

.placeholder {
  color: #b3b3bb;
  font-size: 28rpx;
}

.btn-primary {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6f70ee, #5152d9);
  color: #fff;
  border-radius: 22rpx;
  margin-top: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(81, 82, 217, 0.2);
}

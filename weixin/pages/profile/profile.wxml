<!-- 个人资料 / 密码修改 -->
<view class="profile-page">
  <!-- 头像 -->
  <view class="section-card avatar-card">
    <view class="section-title">头像</view>
    <view class="avatar-row" bindtap="chooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">{{avatarText}}</view>
      <view class="avatar-action">
        <text class="avatar-tip">点击更换头像</text>
        <text class="avatar-format">支持 jpg / png / gif / webp</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section-card">
    <view class="section-title">基本信息</view>
    <view class="form-item">
      <text class="label">用户名</text>
      <text class="readonly">{{username}}</text>
    </view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="field-input" placeholder="请输入昵称" placeholder-class="placeholder" value="{{nickname}}" bindinput="onNickname" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="field-input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder" value="{{phone}}" bindinput="onPhone" />
    </view>
    <button class="btn-primary" bindtap="saveProfile" loading="{{profileSaving}}">保存资料</button>
  </view>

  <!-- 修改密码 -->
  <view class="section-card">
    <view class="section-title">修改密码</view>
    <view class="form-item">
      <text class="label">原密码</text>
      <input class="field-input" placeholder="请输入原密码" placeholder-class="placeholder" password value="{{oldPassword}}" bindinput="onOldPassword" />
    </view>
    <view class="form-item">
      <text class="label">新密码</text>
      <input class="field-input" placeholder="至少6位" placeholder-class="placeholder" password value="{{newPassword}}" bindinput="onNewPassword" />
    </view>
    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="field-input" placeholder="再次输入新密码" placeholder-class="placeholder" password value="{{confirmPassword}}" bindinput="onConfirmPassword" />
    </view>
    <button class="btn-primary" bindtap="changePassword" loading="{{pwdSaving}}">修改密码</button>
  </view>
</view>

<ai-float-btn />

.login-page {
  min-height: 100vh;
  padding: 72rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #f1f1ff 0%, #f6f7fb 38%, #f6f7fb 100%);
}

.login-header {
  text-align: center;
  margin-bottom: 44rpx;
}

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 28rpx;
  color: #fff;
  background: linear-gradient(135deg, #7778f3, #5152d9);
  border-radius: 30rpx;
  font-size: 32rpx;
  font-weight: 750;
  box-shadow: 0 18rpx 40rpx rgba(81, 82, 217, .25);
}

.login-title {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  color: #17171c;
}

.login-sub {
  display: block;
  font-size: 26rpx;
  color: #777780;
  margin-top: 12rpx;
}

.login-form {
  background: #fff;
  border: 1rpx solid rgba(20, 22, 40, 0.05);
  border-radius: 30rpx;
  padding: 12rpx 30rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 18rpx 50rpx rgba(39, 42, 72, 0.08);
}

.form-block {
  border-bottom: 1rpx solid #eff0f4;
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-block .form-item {
  border-bottom: none;
}

.form-block .field-tip {
  border-bottom: none;
}

.label {
  width: 150rpx;
  flex-shrink: 0;
  color: #34343b;
  font-size: 28rpx;
  line-height: 1.4;
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  color: #17171c;
}

.placeholder {
  color: #b3b3bb;
  font-size: 28rpx;
}

.field-tip {
  display: block;
  padding: 0 0 16rpx 150rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.btn-login {
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #6f70ee, #5152d9);
  color: #fff;
  border-radius: 23rpx;
  margin-top: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(81, 82, 217, 0.22);
}

.switch-link {
  text-align: center;
  color: #5152d9;
  font-size: 26rpx;
  margin-top: 30rpx;
}

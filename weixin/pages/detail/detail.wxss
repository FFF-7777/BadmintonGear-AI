.container { padding: 0 0 calc(150rpx + env(safe-area-inset-bottom)); }
.detail-img { width: 100%; height: 660rpx; border-radius: 0 0 36rpx 36rpx; }
.detail-info { background: #fff; padding: 34rpx 30rpx; margin: 22rpx 24rpx 0; border: 1rpx solid rgba(20, 22, 40, 0.05); border-radius: 26rpx; box-shadow: 0 10rpx 30rpx rgba(39, 42, 72, 0.055); }
.detail-price { color: #ff4d67; font-size: 46rpx; font-weight: 750; display: block; letter-spacing: -1rpx; }
.detail-name { color: #17171c; font-size: 34rpx; line-height: 1.4; font-weight: 700; display: block; margin-top: 16rpx; }
.detail-desc { color: #65656e; font-size: 27rpx; display: block; margin-top: 18rpx; line-height: 1.7; }
.detail-stock { color: #a0a0a8; font-size: 23rpx; display: block; margin-top: 20rpx; }
.detail-actions { display: flex; position: fixed; z-index: 20; bottom: 0; left: 0; right: 0; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,.96); box-shadow: 0 -10rpx 30rpx rgba(39, 42, 72, 0.08); }
.detail-actions button { height: 88rpx; line-height: 88rpx; font-size: 28rpx; font-weight: 600; }
.btn-cart { flex: 1; background: #ededff; color: #5152d9; margin-right: 16rpx; border-radius: 22rpx; }
.btn-buy { flex: 1.2; background: linear-gradient(135deg, #6f70ee, #5152d9); color: #fff; border-radius: 22rpx; box-shadow: 0 10rpx 24rpx rgba(81, 82, 217, 0.22); }

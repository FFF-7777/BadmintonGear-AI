.edit-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f6f7fb;
}

.form-card {
  background: #fff;
  border: 1rpx solid rgba(20, 22, 40, 0.05);
  border-radius: 24rpx;
  padding: 0 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 42, 72, 0.05);
}

.form-item {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eff0f4;
}

.textarea-item {
  align-items: flex-start;
  padding: 24rpx 0;
}

.switch-item {
  border-bottom: none;
}

.label {
  width: 150rpx;
  flex-shrink: 0;
  color: #34343b;
  font-size: 28rpx;
}

.field-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 28rpx;
  color: #17171c;
}

.field-textarea {
  flex: 1;
  min-width: 0;
  min-height: 140rpx;
  font-size: 28rpx;
  color: #17171c;
  line-height: 1.6;
}

.placeholder {
  color: #b3b3bb;
  font-size: 28rpx;
}

.btn-save {
  height: 92rpx;
  line-height: 92rpx;
  background: linear-gradient(135deg, #6f70ee, #5152d9);
  color: #fff;
  border-radius: 23rpx;
  margin-top: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(81, 82, 217, 0.22);
}

<!-- 我的页面 -->
<view class="container">
  <view class="user-header">
    <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar">{{avatarText}}</view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
      <text class="username">{{userInfo.username || ''}}</text>
      <text class="welcome-tip">把喜欢的生活慢慢装进口袋</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goProfile">
      <view class="menu-main"><text class="menu-icon purple">人</text><text>个人资料</text></view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAddress">
      <view class="menu-main"><text class="menu-icon blue">址</text><text>收货地址</text></view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goOrders">
      <view class="menu-main"><text class="menu-icon orange">单</text><text>我的订单</text></view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goChat">
      <view class="menu-main"><text class="menu-icon green">AI</text><text>AI 智能客服</text></view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item logout-item" bindtap="handleLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>

<ai-float-btn />

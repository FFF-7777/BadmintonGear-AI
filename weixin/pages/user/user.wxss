.container { padding-top: 18rpx; }
.user-header { position: relative; display: flex; align-items: center; overflow: hidden; background: linear-gradient(135deg, #7475f2 0%, #5152d9 65%, #4647c9 100%); padding: 44rpx 32rpx; border-radius: 30rpx; color: #fff; box-shadow: 0 18rpx 42rpx rgba(81, 82, 217, 0.22); }
.user-header::after { content: ""; position: absolute; right: -40rpx; top: -80rpx; width: 240rpx; height: 240rpx; border: 2rpx solid rgba(255,255,255,.16); border-radius: 50%; }
.avatar, .avatar-img { position: relative; z-index: 1; width: 112rpx; height: 112rpx; border: 4rpx solid rgba(255,255,255,.42); border-radius: 50%; flex-shrink: 0; }
.avatar { background: rgba(255,255,255,.2); text-align: center; line-height: 112rpx; font-size: 40rpx; font-weight: 700; }
.user-info { position: relative; z-index: 1; margin-left: 26rpx; min-width: 0; }
.nickname { display: block; font-size: 35rpx; font-weight: 700; }
.username { display: block; font-size: 23rpx; opacity: .78; margin-top: 6rpx; }
.welcome-tip { display: block; font-size: 21rpx; opacity: .68; margin-top: 12rpx; }
.menu-list { overflow: hidden; background: #fff; border: 1rpx solid rgba(20, 22, 40, 0.05); border-radius: 26rpx; margin-top: 24rpx; box-shadow: 0 10rpx 30rpx rgba(39, 42, 72, 0.055); }
.menu-item { display: flex; justify-content: space-between; align-items: center; min-height: 104rpx; padding: 0 26rpx; border-bottom: 1rpx solid #f0f1f5; box-sizing: border-box; font-size: 28rpx; }
.menu-main { display: flex; align-items: center; }
.menu-icon { display: inline-flex; align-items: center; justify-content: center; width: 54rpx; height: 54rpx; margin-right: 20rpx; border-radius: 16rpx; font-size: 21rpx; font-weight: 700; }
.menu-icon.purple { color: #5b5ce2; background: #ededff; }
.menu-icon.blue { color: #3478f6; background: #eaf2ff; }
.menu-icon.orange { color: #f58b37; background: #fff1e6; }
.menu-icon.green { color: #1f9d67; background: #e7f8f0; }
.arrow { color: #b5b5bd; font-size: 30rpx; }
.logout-item { justify-content: center; border-bottom: none; }
.logout-text { color: #ff4d67; font-weight: 500; }

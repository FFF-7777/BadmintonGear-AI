.container { padding-top: 18rpx; }
.page-intro { display: flex; align-items: center; justify-content: space-between; margin: 12rpx 4rpx 28rpx; }
.eyebrow { display: block; color: #5b5ce2; font-size: 20rpx; font-weight: 700; letter-spacing: 3rpx; }
.page-title { display: block; margin-top: 8rpx; color: #17171c; font-size: 40rpx; line-height: 1.25; font-weight: 700; }
.ai-badge { padding: 12rpx 18rpx; color: #5152d9; background: #ededff; border-radius: 999rpx; font-size: 22rpx; font-weight: 600; }
.banner-swiper { height: 320rpx; border-radius: 28rpx; overflow: hidden; margin-bottom: 36rpx; box-shadow: 0 16rpx 40rpx rgba(39, 42, 72, 0.1); }
.banner-img { width: 100%; height: 100%; }
.section-heading { display: flex; align-items: baseline; justify-content: space-between; margin: 0 4rpx 22rpx; }
.section-title { color: #17171c; font-size: 32rpx; font-weight: 700; }
.section-subtitle { color: #8e8e93; font-size: 23rpx; }
.product-grid { display: flex; flex-wrap: wrap; justify-content: space-between; }
.product-item { width: calc(50% - 10rpx); background: #fff; border: 1rpx solid rgba(20, 22, 40, 0.05); border-radius: 24rpx; overflow: hidden; margin-bottom: 20rpx; box-shadow: 0 8rpx 26rpx rgba(39, 42, 72, 0.055); }
.product-img { width: 100%; height: 310rpx; }
.product-info { padding: 18rpx 20rpx 20rpx; }
.product-name { min-height: 72rpx; color: #25252b; font-size: 27rpx; line-height: 1.45; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.product-bottom { display: flex; flex-direction: column; align-items: flex-start; margin-top: 14rpx; }
.product-price { color: #ff4d67; font-size: 32rpx; font-weight: 700; letter-spacing: -1rpx; }
.product-sales { color: #a0a0a8; font-size: 20rpx; margin-top: 6rpx; }

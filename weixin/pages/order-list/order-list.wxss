.tab-bar { display: flex; background: #ececf2; border-radius: 20rpx; margin-bottom: 24rpx; padding: 6rpx; }
.tab-item { flex: 1; text-align: center; padding: 16rpx 0; border-radius: 15rpx; font-size: 25rpx; color: #73737c; }
.tab-item.active { color: #25252b; background: #fff; font-weight: 650; box-shadow: 0 5rpx 14rpx rgba(39,42,72,.08); }
.order-card { position: relative; background: #fff; border: 1rpx solid rgba(20,22,40,.05); border-radius: 24rpx; padding: 26rpx; margin-bottom: 18rpx; box-shadow: 0 8rpx 24rpx rgba(39,42,72,.05); }
.order-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.order-no { font-size: 23rpx; color: #8e8e93; }
.order-status { color: #5152d9; background: #ededff; border-radius: 999rpx; padding: 5rpx 14rpx; font-size: 22rpx; font-weight: 600; }
.order-item { display: flex; justify-content: space-between; padding: 9rpx 0; font-size: 26rpx; line-height: 1.5; }
.oi-name { flex: 1; }
.oi-price { color: #65656e; }
.order-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 18rpx; padding-top: 18rpx; border-top: 1rpx solid #eff0f4; }
.order-amount { color: #ff4d67; font-weight: 700; }
.order-time { color: #a0a0a8; font-size: 21rpx; }
.btn-pay { min-width: 160rpx; background: linear-gradient(135deg, #6f70ee, #5152d9); color: #fff; border-radius: 18rpx; margin: 18rpx 0 0 auto; font-weight: 600; }

.address-page {
  min-height: 100vh;
  padding: 24rpx 24rpx calc(150rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #f6f7fb;
}

.empty {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  display: block;
  font-size: 30rpx;
  color: #65656e;
}

.empty-tip {
  display: block;
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 16rpx;
}

.address-card {
  background: #fff;
  border: 1rpx solid rgba(20, 22, 40, 0.05);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 24rpx rgba(39, 42, 72, 0.05);
}

.address-top {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #25252b;
  margin-right: 20rpx;
}

.phone {
  font-size: 28rpx;
  color: #73737c;
}

.default-tag {
  margin-left: auto;
  font-size: 22rpx;
  color: #5152d9;
  background: #ededff;
  border-radius: 999rpx;
  padding: 4rpx 14rpx;
}

.address-text {
  display: block;
  font-size: 26rpx;
  color: #65656e;
  line-height: 1.6;
}

.address-actions {
  display: flex;
  justify-content: flex-end;
  gap: 14rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eff0f4;
}

.action-btn {
  font-size: 26rpx;
  color: #5152d9;
  background: #f3f3ff;
  border-radius: 14rpx;
  padding: 10rpx 16rpx;
}

.action-btn.danger {
  color: #ff4d67;
  background: #fff0f2;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,.96);
  box-shadow: 0 -10rpx 30rpx rgba(39, 42, 72, 0.08);
}

.btn-add {
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #6f70ee, #5152d9);
  color: #fff;
  border-radius: 22rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(81, 82, 217, 0.22);
}

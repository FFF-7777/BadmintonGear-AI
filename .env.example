# 羽智选 BadmintonGear AI —— 环境变量示例
# 复制为 .env 并填入真实值。

# ===== 安全配置（生产化必填）=====
# JWT 签名密钥，必须为随机字符串。生成方式：python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=please-generate-a-random-secret-key
# CORS 允许的前端源（逗号分隔）；生产环境改为实际域名
CORS_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174
# 种子管理员初始密码（首次创建 admin 账号时使用）；生产环境务必修改
ADMIN_INIT_PASSWORD=admin

# ===== 大模型 / 向量化（最关键：OPENAI_API_KEY）=====
# 阿里云百炼 OpenAI 兼容地址，或其他兼容 OpenAI 接口的服务商
OPENAI_API_KEY=sk-your-api-key
OPENAI_BASE_URL=https://llm-e7ls8vvabw7yp9a4.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
CHAT_MODEL=qwen3.5-plus
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=2048

# ===== Chroma 向量库 =====
CHROMA_COLLECTION=badminton_rag_knowledge

# ===== RAG 检索参数 =====
RAG_TOP_K=4
RAG_CANDIDATE_K=12
RAG_RRF_K=60
RAG_RELEVANCE_THRESHOLD=0.15
RAG_HISTORY_TURNS=6
RAG_MAX_CONTEXT_CHARS=6000
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===== 接口限制 =====
MAX_MESSAGE_LENGTH=1000
MAX_FILE_SIZE=10485760
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_CHAT=30/minute

# ===== SQLite 数据库（可选覆盖；默认 server/dev.db）=====
# DATABASE_URL=sqlite:///./dev.db

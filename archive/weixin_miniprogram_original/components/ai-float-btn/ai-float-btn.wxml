<!-- AI智选 悬浮按钮（可拖动）— iOS 风格 -->
<view
  class="ai-float-btn"
  hover-class="ai-float-hover"
  style="left:{{x}}px; top:{{y}}px;"
  bindtouchstart="onTouchStart"
  catchtouchmove="onTouchMove"
  bindtouchend="onTouchEnd"
  catchtap="goChat"
>
  <view class="ai-inner">
    <text class="ai-sparkle">✦</text>
    <view class="ai-labels">
      <text class="ai-label-main">AI</text>
      <text class="ai-label-sub">智选</text>
    </view>
  </view>
</view>

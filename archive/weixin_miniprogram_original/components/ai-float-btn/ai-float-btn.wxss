/* ============================================
   AI 智选 悬浮按钮 — iOS 药丸毛玻璃风格
   参考设计：右下角圆角渐变药丸 + "AI 智选" 竖排
   ============================================ */
.ai-float-btn {
  position: fixed;
  width: 108rpx;
  height: 108rpx;
  border-radius: 54rpx;
  background: linear-gradient(145deg, #7C73F0 0%, #5856D6 50%, #4848C4 100%);
  box-shadow:
    0 10rpx 32rpx rgba(88, 86, 214, 0.35),
    0 2rpx 8rpx rgba(88, 86, 214, 0.2),
    inset 0 1rpx 2rpx rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  transition: transform 0.18s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.18s ease;
}

/* iOS 风格按压反馈（弹性缩放） */
.ai-float-hover {
  transform: scale(0.90) !important;
  box-shadow:
    0 4rpx 16rpx rgba(88, 86, 214, 0.3),
    inset 0 1rpx 3rpx rgba(255, 255, 255, 0.28);
}

.ai-inner {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ✦ 星光点缀 */
.ai-sparkle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-right: -2rpx;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.5);
}

.ai-labels {
  display: flex;
  flex-direction: column;
  align-items: center;
  line-height: 1.05;
}

.ai-label-main {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.15);
}

.ai-label-sub {
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

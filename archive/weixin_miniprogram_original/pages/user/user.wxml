<!-- 我的页面 — iOS Young Style -->
<view class="container user-page">
  <!-- 渐变头图卡片（头像 + 昵称 + 签名） -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <image wx:if="{{avatarUrl}}" class="avatar" src="{{avatarUrl}}" mode="aspectFill" />
    <view wx:else class="avatar avatar-placeholder">{{avatarText}}</view>
    <view class="user-detail">
      <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
      <text class="username">{{userInfo.username || ''}}</text>
      <text class="signature">🏸 {{userInfo.nickname ? '热爱羽毛球，精选好装备' : '把喜欢的生活慢慢装进口袋'}}</text>
    </view>
  </view>

  <!-- iOS 分组菜单列表 -->
  <view class="menu-group">
    <view class="menu-item" bindtap="goProfile">
      <view class="menu-left">
        <view class="menu-icon purple">
          <text>👤</text>
        </view>
        <text class="menu-label">个人资料</text>
      </view>
      <text class="menu-arrow">&gt;</text>
    </view>

    <view class="menu-item" bindtap="goAddress">
      <view class="menu-left">
        <view class="menu-icon blue">
          <text>📍</text>
        </view>
        <text class="menu-label">收货地址</text>
      </view>
      <text class="menu-arrow">&gt;</text>
    </view>

    <view class="menu-item" bindtap="goOrders">
      <view class="menu-left">
        <view class="menu-icon orange">
          <text>📦</text>
        </view>
        <text class="menu-label">我的订单</text>
      </view>
      <text class="menu-arrow">&gt;</text>
    </view>

    <view class="menu-item" bindtap="goChat">
      <view class="menu-left">
        <view class="menu-icon green">
          <text>AI</text>
        </view>
        <text class="menu-label">AI 智选服务</text>
      </view>
      <text class="menu-arrow">&gt;</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" bindtap="handleLogout">
    <text class="logout-text">退出登录</text>
  </view>
</view>

<ai-float-btn />

<!-- 首页 — iOS Young Style -->
<view class="container">
  <!-- Hero Banner 区：YOUNG PICKS + 标题 + AI徽章 + 产品图 -->
  <view class="hero-card">
    <view class="hero-text">
      <text class="hero-eyebrow">YOUNG PICKS</text>
      <text class="hero-title">今天想逛点什么？</text>
      <text class="hero-subtitle">羽动生活 · 智选好物</text>
      <view class="ai-tag">
        <text class="ai-tag-icon">✦</text>
        <text class="ai-tag-text">AI 推荐</text>
      </view>
    </view>
    <!-- 轮播图（右侧产品展示） -->
    <swiper class="banner-swiper" indicator-dots indicator-color="rgba(0,0,0,.12)" indicator-active-color="#5856D6" autoplay circular>
      <swiper-item wx:for="{{banners}}" wx:key="id">
        <image class="banner-img" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 服务保障图标行 -->
  <view class="service-row">
    <view class="service-item" wx:for="{{serviceList}}" wx:key="icon">
      <view class="service-icon-wrap {{item.colorClass}}">
        <text class="service-icon">{{item.icon}}</text>
      </view>
      <view class="service-text">
        <text class="service-name">{{item.name}}</text>
        <text class="service-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 热门装备区 -->
  <view class="section-header">
    <text class="section-title">热门装备</text>
    <text class="section-more">大家都在买 &gt;</text>
  </view>

  <!-- 商品双列网格 -->
  <view class="product-grid">
    <view class="product-card" wx:for="{{products}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="product-img-wrap">
        <image class="product-img" src="{{item.image}}" mode="aspectFill" />
        <view class="hot-badge" wx:if="{{index === 0}}">热销</view>
      </view>
      <view class="product-body">
        <text class="product-name">{{item.name}}</text>
        <text class="product-desc">{{item.description || '轻量耐打 · 专业训练推荐'}}</text>
        <view class="product-bottom">
          <text class="product-price">¥{{item.price}}</text>
          <view class="cart-circle" catchtap="addCartQuick" data-id="{{item.id}}">
            <text class="cart-icon">🛒</text>
          </view>
        </view>
        <text class="product-sales">{{item.sales}} 人已买</text>
      </view>
    </view>
  </view>

  <view wx:if="{{products.length === 0}}" class="empty-tip">好物正在上架，稍后再来逛逛</view>
</view>

<ai-float-btn />

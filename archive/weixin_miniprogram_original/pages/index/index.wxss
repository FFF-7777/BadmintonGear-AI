/* ============================================
   首页 — iOS Young Style
   复刻参考设计：Hero Banner + 服务图标行 + 商品网格
   ============================================ */
.container { padding-top: 16rpx; }

/* ====== Hero Banner 卡片（圆角大卡片，内含文字+轮播） ====== */
.hero-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F8F7FF 0%, #EEEDFA 50%, #E8E6FF 100%);
  border-radius: var(--radius-xl);
  padding: 36rpx 28rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  position: relative;
  overflow: hidden;
}
.hero-card::after {
  content: '';
  position: absolute;
  right: -40rpx;
  bottom: -60rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(88,86,214,0.08) 0%, transparent 70%);
}

.hero-text { position: relative; z-index: 1; flex-shrink: 0; width: 52%; }
.hero-eyebrow {
  display: block;
  color: #5856D6;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  margin-bottom: 10rpx;
}
.hero-title {
  display: block;
  font-size: 38rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #1C1C1E;
  margin-bottom: 8rpx;
}
.hero-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8E8E93;
  margin-bottom: 18rpx;
}

/* AI 推荐标签 */
.ai-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 22rpx;
  background: rgba(88, 86, 214, 0.08);
  border-radius: 999rpx;
  border: 1rpx solid rgba(88, 86, 214, 0.12);
}
.ai-tag-icon { font-size: 22rpx; color: #5856D6; margin-right: 6rpx; }
.ai-tag-text { font-size: 23rpx; font-weight: 600; color: #5856D6; }

/* 轮播图（右侧） */
.banner-swiper {
  width: 46%;
  height: 280rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.08);
}
.banner-img { width: 100%; height: 100%; border-radius: var(--radius-lg); }

/* ====== 服务图标行 ====== */
.service-row {
  display: flex;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-sm);
}
.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  flex: 1;
}
.service-icon-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: 22rpx;
  margin-bottom: 10rpx;
}
.service-icon-wrap.purple { background: #EDEAFF; }
.service-icon-wrap.blue { background: #E8F0FF; }
.service-icon-wrap.orange { background: #FFF5EB; }
.service-icon-wrap.cyan { background: #E6F7FF; }
.service-icon { font-size: 34rpx; line-height: 1; }
.service-text { text-align: center; }
.service-name {
  display: block;
  font-size: 23rpx;
  font-weight: 600;
  color: #1C1C1E;
  line-height: 1.2;
}
.service-desc {
  display: block;
  font-size: 19rpx;
  color: #AEAEB2;
  margin-top: 4rpx;
}

/* ====== 分区标题 ====== */
.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin: 0 2rpx 20rpx;
}
.section-title { font-size: 33rpx; font-weight: 700; color: #1C1C1E; }
.section-more { font-size: 24rpx; color: #8E8E93; }

/* ====== 商品网格 ====== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.product-card {
  width: calc(50% - 10rpx);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.15s ease;
}
.product-card:active { transform: scale(0.97); }

/* 图片区 */
.product-img-wrap { position: relative; }
.product-img { width: 100%; height: 300rpx; display: block; }
.hot-badge {
  position: absolute;
  top: 14rpx;
  left: 14rpx;
  padding: 4rpx 14rpx;
  background: linear-gradient(135deg, #FF9500, #FF6B00);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 999rpx;
}

/* 商品信息 */
.product-body { padding: 16rpx 18rpx 20rpx; }
.product-name {
  display: block;
  min-height: 72rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #1C1C1E;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-desc {
  display: block;
  font-size: 21rpx;
  color: #AEAEB2;
  margin-top: 6rpx;
  line-height: 1.35;
}
.product-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 14rpx;
}
.product-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--price);
  letter-spacing: -0.5rpx;
}

/* 购物车圆形按钮 */
.cart-circle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 2rpx solid #E5E5EA;
  background: #fff;
  transition: all 0.15s ease;
}
.cart-circle:active {
  border-color: #5856D6;
  background: var(--primary-light);
}
.cart-icon { font-size: 26rpx; line-height: 1; }

.product-sales {
  display: block;
  font-size: 20rpx;
  color: #AEAEB2;
  margin-top: 8rpx;
}

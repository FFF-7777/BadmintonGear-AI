<!-- 登录 / 注册页面 — iOS Young Style -->
<view class="login-page">
  <!-- 头部品牌区 -->
  <view class="login-header">
    <view class="brand-mark">AI</view>
    <text class="login-title">{{isRegister ? '创建你的新账号' : '欢迎回来'}}</text>
    <text class="login-sub">{{isRegister ? '简单几步，开始发现喜欢的好物' : '登录后继续你的好物清单'}}</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form" wx:if="{{!isRegister}}">
    <view class="form-item">
      <text class="label">用户名</text>
      <input class="field-input" placeholder="请输入用户名" placeholder-class="placeholder" value="{{username}}" bindinput="onUsername" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="field-input" placeholder="请输入密码" placeholder-class="placeholder" password value="{{password}}" bindinput="onPassword" />
    </view>
    <button class="btn-login" bindtap="handleLogin" loading="{{loading}}">登录</button>
    <view class="switch-link" bindtap="switchToRegister">没有账号？立即注册</view>
  </view>

  <!-- 注册表单 -->
  <view class="login-form register-form" wx:else>
    <view class="form-block">
      <view class="form-item">
        <text class="label">用户名</text>
        <input class="field-input" placeholder="请输入用户名" placeholder-class="placeholder" value="{{regUsername}}" bindinput="onRegUsername" />
      </view>
      <text class="field-tip">3-20位字母、数字或下划线</text>
    </view>
    <view class="form-item">
      <text class="label">昵称</text>
      <input class="field-input" placeholder="请输入昵称" placeholder-class="placeholder" value="{{nickname}}" bindinput="onNickname" />
    </view>
    <view class="form-item">
      <text class="label">手机号</text>
      <input class="field-input" type="number" maxlength="11" placeholder="选填" placeholder-class="placeholder" value="{{phone}}" bindinput="onPhone" />
    </view>
    <view class="form-item">
      <text class="label">密码</text>
      <input class="field-input" placeholder="至少6位" placeholder-class="placeholder" password value="{{regPassword}}" bindinput="onRegPassword" />
    </view>
    <view class="form-item">
      <text class="label">确认密码</text>
      <input class="field-input" placeholder="再次输入密码" placeholder-class="placeholder" password value="{{confirmPassword}}" bindinput="onConfirmPassword" />
    </view>
    <button class="btn-login" bindtap="handleRegister" loading="{{loading}}">创建账号</button>
    <view class="switch-link" bindtap="switchToLogin">已有账号？立即登录</view>
  </view>
</view>


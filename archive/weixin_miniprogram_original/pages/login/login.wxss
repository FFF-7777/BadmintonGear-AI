/* ============================================
   登录注册页 — iOS Young Style
   品牌卡片 + iOS 表单风格
   ============================================ */
.login-page {
  min-height: 100vh;
  padding: 72rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: linear-gradient(180deg, #EEEDFA 0%, var(--bg-page) 35%, var(--bg-page) 100%);
}

.login-header { text-align: center; margin-bottom: 48rpx; }

.brand-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  margin: 0 auto 28rpx;
  color: #fff;
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  border-radius: 32rpx;
  font-size: 36rpx;
  font-weight: 750;
  letter-spacing: 2rpx;
  box-shadow: 0 18rpx 44rpx rgba(88, 86, 214, 0.3);
}

.login-title { display: block; font-size: 42rpx; font-weight: 700; color: #1C1C1E; }
.login-sub { display: block; font-size: 26rpx; color: #8E8E93; margin-top: 10rpx; }

/* iOS 表单卡片 */
.login-form {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: 12rpx 32rpx 38rpx;
  box-sizing: border-box;
  box-shadow: var(--shadow-md);
}
.form-block { border-bottom: 1rpx solid #F2F2F7; }
.form-item {
  display: flex;
  align-items: center;
  min-height: 104rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F2F2F7;
}
.form-block .form-item { border-bottom: none; }
.label { width: 150rpx; flex-shrink: 0; color: #3A3A3C; font-size: 28rpx; font-weight: 500; }
.field-input {
  flex: 1; min-width: 0; height: 68rpx; line-height: 68rpx;
  font-size: 29rpx; color: #1C1C1E;
}
.placeholder { color: #C7C7CC; font-size: 28rpx; }
.field-tip { display: block; padding: 0 0 18rpx 150rpx; font-size: 22rpx; color: #AEAEB2; line-height: 1.5; }

/* 登录按钮 */
.btn-login {
  height: 96rpx; line-height: 96rpx;
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  color: #fff; border-radius: 26rpx;
  margin-top: 44rpx; font-size: 31rpx; font-weight: 600;
  box-shadow: 0 14rpx 32rpx rgba(88, 86, 214, 0.26);
  transition: transform 0.15s ease;
}
.btn-login:active { transform: scale(0.97); opacity: 0.9; }
.switch-link { text-align: center; color: #5856D6; font-size: 27rpx; margin-top: 34rpx; }
.switch-link:active { opacity: 0.6; }

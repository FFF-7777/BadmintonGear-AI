/* ============================================
   地址列表 — iOS Young Style
   圆角卡片 + 毛玻璃底部栏
   ============================================ */
.address-page {
  min-height: 100vh;
  padding: 20rpx 24rpx calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box; background: var(--bg-page);
}

/* 空态 */
.empty-state { padding: 120rpx 0; text-align: center; }
.empty-icon { font-size: 64rpx; display: block; margin-bottom: 16rpx; }
.empty-text { display: block; font-size: 31rpx; color: #8E8E93; font-weight: 500; }
.empty-tip { display: block; font-size: 25rpx; color: #AEAEB2; margin-top: 10rpx; }

/* 地址卡片 */
.addr-card {
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 28rpx; margin-bottom: 18rpx; box-shadow: var(--shadow-sm);
}
.addr-top { display: flex; align-items: center; flex-wrap: wrap; margin-bottom: 12rpx; }
.name { font-size: 31rpx; font-weight: 700; color: #1C1C1E; margin-right: 20rpx; }
.phone { font-size: 28rpx; color: #8E8E93; }
.default-tag {
  margin-left: auto; font-size: 22rpx; color: #5856D6;
  background: var(--primary-light); border-radius: 999rpx; padding: 4rpx 16rpx;
}
.addr-text { display: block; font-size: 27rpx; color: #8E8E93; line-height: 1.6; }

/* 操作按钮行 */
.addr-actions {
  display: flex; justify-content: flex-end; gap: 14rpx;
  margin-top: 22rpx; padding-top: 22rpx; border-top: 1rpx solid #F2F2F7;
}
.action-btn {
  font-size: 26rpx; color: #5856D6; background: var(--primary-light);
  border-radius: 999rpx; padding: 10rpx 20rpx; font-weight: 500;
}
.action-btn.danger { color: var(--price); background: rgba(255,59,48,0.06); }

/* 底部栏 */
.footer-bar { padding: 16rpx 24rpx calc(22rpx + env(safe-area-inset-bottom)); }
.btn-add {
  width: 100%; height: 92rpx; line-height: 92rpx;
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  color: #fff; border-radius: var(--radius-lg);
  font-size: 30rpx; font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(88, 86, 214, 0.25);
}
.btn-add:active { transform: scale(0.97); opacity: 0.9; }

/* ============================================
   详情页 — iOS Young Style
   大图 + 圆角信息卡 + 毛玻璃操作栏
   ============================================ */
.detail-page { padding: 0; }

.img-wrap {
  border-radius: 0 0 var(--radius-xl) var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-md);
}
.detail-img { width: 100%; height: 660rpx; display: block; }

.info-card {
  background: var(--bg-card);
  margin: -30rpx 24rpx 0;
  padding: 32rpx 28rpx;
  border-radius: var(--radius-xl);
  position: relative;
  z-index: 2;
  box-shadow: var(--shadow-md);
}
.price-row { display: flex; align-items: baseline; }
.detail-price {
  font-size: 48rpx;
  font-weight: 750;
  color: var(--price);
  letter-spacing: -1rpx;
}
.detail-name {
  display: block;
  font-size: 34rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #1C1C1E;
  margin-top: 16rpx;
}
.detail-desc {
  display: block;
  font-size: 27rpx;
  color: #8E8E93;
  margin-top: 14rpx;
  line-height: 1.7;
}
.stock-row { display: flex; align-items: center; margin-top: 22rpx; }
.stock-text { font-size: 24rpx; color: #AEAEB2; }
.divider-dot { margin: 0 12rpx; color: #D1D1D6; }

/* 底部操作栏 */
.action-bar {
  display: flex;
  gap: 18rpx;
  padding: 16rpx 24rpx calc(22rpx + env(safe-area-inset-bottom));
}
.action-bar button {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 29rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  margin: 0;
}
.btn-cart {
  flex: 1;
  background: #F2F2F7;
  color: #5856D6;
  transition: transform 0.15s ease;
}
.btn-cart:active { transform: scale(0.97); }
.btn-buy {
  flex: 1.3;
  background: linear-gradient(135deg, #7C73F0, #5856D6);
  color: #fff;
  box-shadow: 0 10rpx 28rpx rgba(88, 86, 214, 0.25);
  transition: transform 0.15s ease;
}
.btn-buy:active { transform: scale(0.97); opacity: 0.9; }

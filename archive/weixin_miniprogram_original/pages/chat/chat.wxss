/* ============================================
   AI 智能客服对话页 — iOS Young Style
   毛玻璃输入栏 · iOS 气泡 · 流式动画
   ============================================ */

/* ====== 布局 ====== */
.chat-page { display: flex; flex-direction: column; height: 100vh; background: linear-gradient(180deg, #F4F3FF 0%, var(--bg-page) 20%); }
.chat-list { flex: 1; overflow-y: auto; box-sizing: border-box; padding: 24rpx 0 28rpx; }

/* ====== 消息项 ====== */
.chat-item { margin-bottom: 28rpx; padding: 0 24rpx; box-sizing: border-box; }
.chat-item.user { display: flex; flex-direction: column; align-items: flex-end; }
.chat-item.assistant { display: flex; flex-direction: column; align-items: flex-start; }

/* ====== 用户气泡 — iOS 蓝紫渐变 ====== */
.chat-bubble { max-width: 80%; padding: 22rpx 26rpx; border-radius: 24rpx; font-size: 28rpx; line-height: 1.72; word-break: break-all; box-sizing: border-box; }
.user-bubble {
  background: linear-gradient(145deg, #7C73F0, #5856D6); color: #fff;
  border-bottom-right-radius: 10rpx;
  box-shadow: 0 8rpx 24rpx rgba(88, 86, 214, 0.2);
}

/* ====== AI 气泡 — 白底圆角卡 ====== */
.ai-bubble {
  position: relative; overflow: hidden;
  background: var(--bg-card); color: #1C1C1E;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-bottom-left-radius: 10rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
}

.source-list { margin-top: 18rpx; padding-top: 14rpx; border-top: 1rpx solid #F2F2F7; }
.source-title { display: block; color: #AEAEB2; font-size: 22rpx; margin-bottom: 8rpx; }
.source-item { display: block; color: #5856D6; font-size: 22rpx; line-height: 1.55; }

/* 时间戳 */
.chat-time { display: block; font-size: 20rpx; color: #C7C7CC; margin-top: 8rpx; text-align: center; }

/* ====== iOS 毛玻璃输入栏 ====== */
.chat-input-bar {
  display: flex; align-items: center; gap: 14rpx;
  padding: 16rpx 22rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255,255,255,.85);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border-top: 1rpx solid rgba(0,0,0,.03);
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,.03);
}
.glass-bar-input { /* 不使用 .glass-bar 的 fixed 定位 */ }
.chat-input {
  flex: 1; height: 76rpx; box-sizing: border-box;
  background: #F2F2F7; border-radius: 24rpx;
  padding: 0 24rpx; font-size: 27rpx; color: #1C1C1E;
}
.btn-send {
  min-width: 120rpx; height: 76rpx; line-height: 76rpx;
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  color: #fff; font-size: 27rpx; font-weight: 600;
  padding: 0 26rpx; border-radius: 24rpx; border: none;
  transition: transform 0.15s ease;
}
.btn-send:active { transform: scale(0.95); opacity: 0.88; }
.btn-send[disabled] { opacity: 0.45; }

/* ====== iOS 流式思考动画（弹性跳动点）====== */
.streaming-placeholder { display: flex; align-items: center; gap: 16rpx; padding: 8rpx 0; }
.thinking-dots { display: flex; gap: 8rpx; align-items: center; }
.dot {
  display: inline-block; width: 14rpx; height: 14rpx; border-radius: 50%;
  background: #5856D6; animation: bounce 1.4s ease-in-out infinite;
}
.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.16s; }
.dot-3 { animation-delay: 0.32s; }
@keyframes bounce {
  0%, 80%, 100% { transform: translateY(0); opacity: 0.35; }
  40% { transform: translateY(-12rpx); opacity: 1; }
}
.thinking-text { font-size: 25rpx; color: #AEAEB2; font-style: italic; }

/* ====== Markdown 渲染样式（rich-text 内嵌节点）====== */
.ai-bubble p { margin: 10rpx 0; line-height: 1.75; }
.ai-bubble strong, .ai-bubble b { color: #1C1C1E; font-weight: 650; }
.ai-bubble em, .ai-bubble i { font-style: italic; color: #5856D6; }
.ai-bubble code {
  background: #F2F2F7; color: #FF3B30;
  padding: 3rpx 12rpx; border-radius: 8rpx;
  font-size: 25rpx; font-family: SF Mono, Menlo, Consolas, monospace;
}
.ai-bubble pre {
  background: #1C1C1E; color: #F5F5F7;
  padding: 24rpx; border-radius: 16rpx;
  margin: 14rpx 0; overflow-x: auto; white-space: pre-wrap; word-break: break-all;
}
.ai-bubble pre code { background: transparent; color: inherit; padding: 0; font-size: 23rpx; }
.ai-bubble ul.md-list, .ai-bubble ol { margin: 10rpx 0; padding-left: 38rpx; }
.ai-bubble li { margin: 8rpx 0; line-height: 1.72; list-style-position: outside; }
.ai-bubble ul.md-list { list-style-type: disc; }
.ai-bubble ul.md-list > li::marker { color: #5856D6; font-size: 24rpx; }
.ai-bubble blockquote {
  border-left: 6rpx solid #5856D6; padding: 14rpx 22rpx;
  margin: 14rpx 0; background: #F8F7FF;
  color: #666; border-radius: 0 14rpx 14rpx 0;
}
.ai-bubble h1 { font-size: 38rpx; font-weight: 750; margin: 18rpx 0 10rpx; color: #1C1C1E; }
.ai-bubble h2 { font-size: 34rpx; font-weight: 720; margin: 16rpx 0 8rpx; color: #222; }
.ai-bubble h3 { font-size: 30rpx; font-weight: 700; margin: 14rpx 0 6rpx; color: #333; }
.ai-bubble br { display: block; content: ''; margin: 6rpx 0; }

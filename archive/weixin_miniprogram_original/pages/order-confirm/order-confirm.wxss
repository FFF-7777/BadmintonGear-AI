/* ============================================
   确认订单 — iOS Young Style
   地址卡 + 表单卡 + 毛玻璃提交栏
   ============================================ */
.container { padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }

/* 地址选择卡 */
.address-card {
  display: flex; align-items: center; background: var(--bg-card);
  border-radius: var(--radius-lg); padding: 30rpx 26rpx;
  margin-bottom: 18rpx; box-shadow: var(--shadow-sm);
}
.address-main { flex: 1; min-width: 0; }
.addr-row { display: flex; align-items: center; flex-wrap: wrap; margin-bottom: 10rpx; }
.name { font-size: 31rpx; font-weight: 700; color: #1C1C1E; margin-right: 20rpx; }
.phone { font-size: 28rpx; color: #8E8E93; }
.default-tag {
  margin-left: 12rpx; font-size: 22rpx; color: #5856D6;
  background: var(--primary-light); border-radius: 999rpx; padding: 4rpx 16rpx;
}
.addr-text { display: block; font-size: 27rpx; color: #8E8E93; line-height: 1.6; }
.no-address-text { display: block; font-size: 31rpx; color: #1C1C1E; }
.no-address-tip { display: block; font-size: 25rpx; color: #8E8E93; margin-top: 8rpx; }
.arrow { color: #C7C7CC; font-size: 34rpx; margin-left: 16rpx; }

/* iOS 表单卡 */
.form-card-ios {
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 0 24rpx; box-shadow: var(--shadow-sm);
}
.form-item-ios {
  display: flex; align-items: center; min-height: 108rpx;
  border-bottom: 1rpx solid #F2F2F7;
}
.form-item-ios:last-child { border-bottom: none; }
.label-ios { width: 100rpx; flex-shrink: 0; color: #8E8E93; font-size: 28rpx; font-weight: 500; }
.form-item-ios input {
  flex: 1; min-width: 0; height: 68rpx; line-height: 68rpx;
  font-size: 29rpx; color: #1C1C1E;
}
.placeholder-ios { color: #C7C7CC; font-size: 28rpx; }

/* 提交栏 */
.submit-bar { padding: 18rpx 24rpx calc(22rpx + env(safe-area-inset-bottom)); }
.btn-submit {
  width: 100%; height: 92rpx; line-height: 92rpx;
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  color: #fff; border-radius: var(--radius-lg);
  font-size: 30rpx; font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(88, 86, 214, 0.25);
  transition: transform 0.15s ease;
}
.btn-submit:active { transform: scale(0.97); opacity: 0.9; }

/* ============================================
   地址编辑 — iOS Young Style
   iOS 风格表单 + 渐变按钮
   ============================================ */
.edit-page {
  min-height: 100vh;
  padding: 20rpx 24rpx; box-sizing: border-box; background: var(--bg-page);
}
.form-card-ios {
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 0 30rpx; box-shadow: var(--shadow-sm);
}
.form-item-ios {
  display: flex; align-items: center; min-height: 108rpx;
  padding: 12rpx 0; border-bottom: 1rpx solid #F2F2F7;
}
.textarea-ios { align-items: flex-start; padding: 26rpx 0; }
.switch-ios { border-bottom: none; }
.label-ios { width: 150rpx; flex-shrink: 0; color: #3A3A3C; font-size: 28rpx; font-weight: 500; }
.field-ios {
  flex: 1; min-width: 0; height: 68rpx; line-height: 68rpx;
  font-size: 29rpx; color: #1C1C1E;
}
.field-textarea-ios {
  flex: 1; min-width: 0; min-height: 140rpx;
  font-size: 29rpx; color: #1C1C1E; line-height: 1.6;
}
.placeholder-ios { color: #C7C7CC; font-size: 28rpx; }

.btn-save {
  height: 96rpx; line-height: 96rpx;
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  color: #fff; border-radius: 26rpx; margin-top: 40rpx;
  font-size: 31rpx; font-weight: 600;
  box-shadow: 0 14rpx 32rpx rgba(88, 86, 214, 0.25);
}
.btn-save:active { transform: scale(0.97); opacity: 0.9; }

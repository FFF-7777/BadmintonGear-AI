<!-- 编辑收货地址 — iOS Young Style -->
<view class="edit-page">
  <!-- 表单卡 -->
  <view class="form-card-ios">
    <view class="form-item-ios">
      <text class="label-ios">收货人</text>
      <input class="field-ios" placeholder="请输入收货人" placeholder-class="placeholder-ios" value="{{name}}" bindinput="onName" />
    </view>
    <view class="form-item-ios">
      <text class="label-ios">联系电话</text>
      <input class="field-ios" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder-ios" value="{{phone}}" bindinput="onPhone" />
    </view>
    <view class="form-item-ios textarea-ios">
      <text class="label-ios">详细地址</text>
      <textarea class="field-textarea-ios" placeholder="省市区、街道、门牌号等" placeholder-class="placeholder-ios" value="{{address}}" bindinput="onAddress" maxlength="255" />
    </view>
    <view class="form-item-ios switch-ios">
      <text class="label-ios">设为默认</text>
      <switch checked="{{isDefault}}" color="#5856D6" bindchange="onDefaultChange" />
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="btn-save" bindtap="saveAddress" loading="{{saving}}">保存地址</button>
</view>

<ai-float-btn />

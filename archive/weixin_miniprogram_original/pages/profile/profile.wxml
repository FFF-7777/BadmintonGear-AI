<!-- 个人资料 / 密码修改 — iOS Young Style -->
<view class="profile-page">
  <!-- 头像区 -->
  <view class="section-card">
    <text class="section-title">头像</text>
    <view class="avatar-row" bindtap="chooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">{{avatarText}}</view>
      <view class="avatar-action">
        <text class="avatar-tip">点击更换头像</text>
        <text class="avatar-format">支持 jpg / png / gif / webp</text>
      </view>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section-card">
    <text class="section-title">基本信息</text>
    <view class="form-item-ios">
      <text class="label-ios">用户名</text>
      <text class="readonly-val">{{username}}</text>
    </view>
    <view class="form-item-ios">
      <text class="label-ios">昵称</text>
      <input class="field-ios" placeholder="请输入昵称" placeholder-class="placeholder-ios" value="{{nickname}}" bindinput="onNickname" />
    </view>
    <view class="form-item-ios">
      <text class="label-ios">手机号</text>
      <input class="field-ios" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder-ios" value="{{phone}}" bindinput="onPhone" />
    </view>
    <button class="btn-primary btn-save-profile" bindtap="saveProfile" loading="{{profileSaving}}">保存资料</button>
  </view>

  <!-- 修改密码 -->
  <view class="section-card">
    <text class="section-title">修改密码</text>
    <view class="form-item-ios">
      <text class="label-ios">原密码</text>
      <input class="field-ios" placeholder="请输入原密码" placeholder-class="placeholder-ios" password value="{{oldPassword}}" bindinput="onOldPassword" />
    </view>
    <view class="form-item-ios">
      <text class="label-ios">新密码</text>
      <input class="field-ios" placeholder="至少6位" placeholder-class="placeholder-ios" password value="{{newPassword}}" bindinput="onNewPassword" />
    </view>
    <view class="form-item-ios">
      <text class="label-ios">确认密码</text>
      <input class="field-ios" placeholder="再次输入新密码" placeholder-class="placeholder-ios" password value="{{confirmPassword}}" bindinput="onConfirmPassword" />
    </view>
    <button class="btn-primary btn-save-pwd" bindtap="changePassword" loading="{{pwdSaving}}">修改密码</button>
  </view>
</view>

<ai-float-btn />

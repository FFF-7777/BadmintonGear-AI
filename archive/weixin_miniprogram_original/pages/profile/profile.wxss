/* ============================================
   个人资料 — iOS Young Style
   分组卡片 + iOS 表单风格
   ============================================ */
.profile-page {
  min-height: 100vh;
  padding: 20rpx 24rpx; box-sizing: border-box; background: var(--bg-page);
}

.section-card {
  background: var(--bg-card); border-radius: var(--radius-lg);
  padding: 30rpx; margin-bottom: 18rpx; box-shadow: var(--shadow-sm);
}
.section-title { font-size: 31rpx; font-weight: 700; color: #1C1C1E; margin-bottom: 24rpx; }

.avatar-row { display: flex; align-items: center; }
.avatar-img, .avatar-placeholder { width: 120rpx; height: 120rpx; border-radius: 50%; flex-shrink: 0; }
.avatar-placeholder {
  background: linear-gradient(145deg, #7C73F0, #5856D6);
  color: #fff; text-align: center; line-height: 120rpx;
  font-size: 44rpx; font-weight: 700;
  box-shadow: 0 10rpx 28rpx rgba(88, 86, 214, 0.22);
}
.avatar-action { margin-left: 26rpx; }
.avatar-tip { display: block; font-size: 29rpx; color: #5856D6; font-weight: 600; }
.avatar-format { display: block; font-size: 23rpx; color: #AEAEB2; margin-top: 8rpx; }

/* 表单 */
.form-item-ios {
  display: flex; align-items: center; min-height: 108rpx;
  padding: 12rpx 0; border-bottom: 1rpx solid #F2F2F7;
}
.label-ios { width: 150rpx; flex-shrink: 0; color: #3A3A3C; font-size: 28rpx; font-weight: 500; }
.readonly-val { flex: 1; font-size: 28rpx; color: #8E8E93; }
.field-ios { flex: 1; min-width: 0; height: 68rpx; line-height: 68rpx; font-size: 29rpx; color: #1C1C1E; }
.placeholder-ios { color: #C7C7CC; font-size: 28rpx; }

.btn-save-profile, .btn-save-pwd {
  height: 88rpx; line-height: 88rpx; margin-top: 32rpx;
  border-radius: var(--radius-lg);
  font-size: 29rpx; font-weight: 600;
}
.btn-save-profile:active, .btn-save-pwd:active { transform: scale(0.97); opacity: 0.9; }

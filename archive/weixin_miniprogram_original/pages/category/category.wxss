/* ============================================
   分类页 — iOS Young Style
   左侧分类栏 + 右侧商品横排卡片列表
   ============================================ */
.category-page {
  display: flex;
  height: 100vh;
  background: var(--bg-page);
}

/* ====== 左侧分类栏 ====== */
.cat-sidebar {
  width: 180rpx;
  padding: 20rpx 12rpx;
  box-sizing: border-box;
  background: #F0F0F5;
}

.cat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  padding: 26rpx 10rpx;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}
.cat-item .cat-icon {
  font-size: 32rpx;
  line-height: 1;
  margin-bottom: 6rpx;
  opacity: 0.6;
}
.cat-item .cat-name {
  font-size: 24rpx;
  color: #8E8E93;
  text-align: center;
  line-height: 1.3;
  font-weight: 500;
}

/* 选中态 — 蓝紫色高亮 + 白底 + 阴影 */
.cat-item.active {
  background: var(--bg-card);
  box-shadow: var(--shadow-sm);
}
.cat-item.active .cat-icon { opacity: 1; }
.cat-item.active .cat-name {
  color: #5856D6;
  font-weight: 700;
}

/* ====== 右侧内容区 ====== */
.cat-content {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 16rpx;
  box-sizing: border-box;
}

/* 商品横排卡片（大圆角，参考图风格） */
.product-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 18rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.15s ease;
}
.product-card:active { transform: scale(0.98); }

.product-img {
  width: 170rpx;
  height: 170rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.product-info {
  flex: 1;
  min-width: 0;
  padding-left: 22rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.product-name {
  color: #1C1C1E;
  font-size: 29rpx;
  line-height: 1.4;
  font-weight: 600;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-desc {
  display: block;
  font-size: 23rpx;
  color: #AEAEB2;
  margin-top: 8rpx;
  line-height: 1.35;
}
.product-price {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #5856D6;  /* 分类页价格用主色蓝紫（参考图） */
  margin-top: 14rpx;
  letter-spacing: -0.5rpx;
}

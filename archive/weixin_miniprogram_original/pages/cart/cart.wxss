/* ============================================
   购物车 — iOS Young Style
   圆角卡片列表 + 毛玻璃结算栏 + iOS 控件样式
   ============================================ */
.container { padding-bottom: calc(160rpx + env(safe-area-inset-bottom)); }

/* ====== 商品卡片 ====== */
.cart-card {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 22rpx 18rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  transition: transform 0.12s ease;
}
.card-hover { transform: scale(0.98); }

/* 圆形勾选框 */
.check-wrap { margin-right: 16rpx; flex-shrink: 0; }
.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid #D1D1D6;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}
.check-circle.checked {
  background: #5856D6;
  border-color: #5856D6;
  box-shadow: 0 2rpx 10rpx rgba(88, 86, 214, 0.3);
}
.check-mark {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

/* 商品图片 */
.cart-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-md);
  flex-shrink: 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 商品信息 */
.cart-info { flex: 1; min-width: 0; padding: 0 14rpx; }
.cart-name {
  display: block;
  font-size: 27rpx;
  line-height: 1.4;
  color: #1C1C1E;
  font-weight: 500;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cart-price {
  display: block;
  font-size: 31rpx;
  font-weight: 700;
  color: var(--price);
  margin-top: 10rpx;
  letter-spacing: -0.5rpx;
}

/* 数量控制（iOS 风格圆按钮）*/
.qty-row {
  display: flex;
  align-items: center;
  margin-top: 14rpx;
}
.qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: #F2F2F7;
  font-size: 30rpx;
  font-weight: 300;
  color: #5856D6;
  transition: all 0.15s ease;
}
.qty-btn:active { background: #EDEAFF; transform: scale(0.92); }
.qty-num {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1C1C1E;
}

/* 删除 */
.cart-del {
  font-size: 24rpx;
  color: #AEAEB2;
  padding: 20rpx 8rpx;
  flex-shrink: 0;
}
.cart-del:active { color: var(--price); }

/* ====== 底部毛玻璃结算栏 ====== */
.checkout-bar {
  position: fixed;
  z-index: 100;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 28rpx calc(22rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.82);
  backdrop-filter: blur(25px);
  -webkit-backdrop-filter: blur(25px);
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.04);
}
.total-area { display: flex; align-items: baseline; }
.total-label {
  font-size: 24rpx;
  color: #8E8E93;
  margin-right: 8rpx;
}
.total-amount {
  font-size: 36rpx;
  font-weight: 750;
  color: var(--price);
  letter-spacing: -0.5rpx;
}

/* 结算渐变按钮 */
.btn-checkout {
  min-width: 240rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #7C73F0 0%, #5856D6 100%);
  color: #fff;
  font-size: 29rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  margin: 0;
  box-shadow: 0 10rpx 28rpx rgba(88, 86, 214, 0.28);
  transition: transform 0.15s ease;
}
.btn-checkout:active { transform: scale(0.97); opacity: 0.9; }
